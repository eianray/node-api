# Meridian GIS API — Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://meridian:meridian@localhost:5432/meridian

# x402 / USDC Payments
# Set WALLET_ADDRESS to your Base L2 wallet address to enable real payment verification.
# Zero address = dev mode (bypasses on-chain verification for local testing).
WALLET_ADDRESS=0x0000000000000000000000000000000000000000
X402_FACILITATOR_URL=https://x402.org/facilitate

# File limits
MAX_UPLOAD_MB=50
